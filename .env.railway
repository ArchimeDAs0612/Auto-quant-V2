# Railway 部署环境变量
# 请在 Railway Dashboard 中配置以下变量

# 服务器配置
PORT=3001
NODE_ENV=production

# PushPlus通知配置
PUSHPLUS_TOKEN=aab835d141754e6e9c0d31a4768467b7

# 交易参数配置
INITIAL_BALANCE=1000
MAX_LEVERAGE=10
MIN_RR=3
MIN_STOP_LOSS_POINTS=500
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.06
MAX_DRAWDOWN=0.15

# Railway PostgreSQL 数据库
# Railway 会自动设置 DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OKX API配置（可选）
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=