{
  "name": "btc-trend-following-system",
  "version": "1.0.0",
  "description": "BTC低频趋势跟随量化交易系统",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "install-all": "npm install && npm run install-client",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "postinstall": "cd client && npm install && cd .. && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "https-proxy-agent": "^9.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socks-proxy-agent": "^10.0.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "bitcoin",
    "trading",
    "quantitative",
    "trend-following",
    "okx"
  ],
